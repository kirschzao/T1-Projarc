				{
					"name": "Listar Todos os Cardapios (ADMIN)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Auto-login como ADMIN (patinhas) -> jwt_admin",
									"pm.sendRequest({",
									"    url: pm.collectionVariables.get(\"baseUrl\") + \"/auth/login\",",
									"    method: \"POST\",",
									"    header: { \"Content-Type\": \"application/json\" },",
									"    body: { mode: \"raw\", raw: JSON.stringify({ email: \"patinhas@email.com\", senha: \"123456\" }) }",
									"}, (err, res) => {",
									"    if (!err && res.code === 200) pm.collectionVariables.set(\"jwt_admin\", res.json().token);",
									"    else console.warn(\"Falha no auto-login ADMIN:\", err || res.code);",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_admin}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/cardapio/lista",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"cardapio",
								"lista"
							]
						},
						"description": "Lista todos os cardapios (UC1 - Adm). Rota restrita a ADMIN no gateway. O pre-request faz login como patinhas@email.com (ADMIN) e usa esse token."
					},
					"response": []
