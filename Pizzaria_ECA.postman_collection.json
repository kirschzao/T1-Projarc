								},
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/pedidos/{{last_pedido_margarida_id}}",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"pedidos",
										"{{last_pedido_margarida_id}}"
									]
								},
								"description": "Consulta o status do pedido de Margarida usando as credenciais explícitas dela."
							},
							"response": []
						},
						{
							"name": "UC6.1 - Cancelar Pedido",
							"request": {
								"auth": {
									"type": "basic",
									"basic": [
										{
											"key": "password",
											"value": "123456",
											"type": "string"
										},
										{
											"key": "username",
											"value": "margarida@email.com",
											"type": "string"
										}
									]
								},
								"method": "POST",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/pedidos/{{last_pedido_margarida_id}}/cancelar",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"pedidos",
										"{{last_pedido_margarida_id}}",
										"cancelar"
									]
								},
								"description": "Cancela o pedido de Margarida usando as credenciais explícitas dela."
							},
							"response": []
						}
					]
				},
				{
					"name": "C. Histórico e Outros",
					"item": [
						{
							"name": "UC5.1 - Consultar Status de Pedido Histórico (Luizinho)",
							"request": {
								"auth": {
									"type": "basic",
									"basic": [
										{
											"key": "password",
											"value": "123456",
											"type": "string"
										},
										{
											"key": "username",
											"value": "zezinho.pato@email.com",
											"type": "string"
										}
									]
								},
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/pedidos/8",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"pedidos",
										"8"
							]
								},
								"description": "Consulta o pedido ID 8 (pré-populado no data.sql). Como ele pertence ao CPF 9002 (Luizinho Pato, cujo e-mail cadastrado no seed é zezinho.pato@email.com), passamos explicitamente a autenticação dele para não haver 403."
							},
							"response": []
						},
						{
							"name": "UC8 - Listar Pedidos Entregues (Período Geral)",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/pedidos/entregues?inicio=2026-05-01T00:00:00&fim=2026-05-31T23:59:59",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"pedidos",
										"entregues"
									],
									"query": [
										{
											"key": "inicio",
											"value": "2026-05-01T00:00:00"
										},
										{
											"key": "fim",
											"value": "2026-05-31T23:59:59"
										}
									]
								},
								"description": "Retorna todos os pedidos de todos os clientes que estão no status `ENTREGUE` no período de datas selecionado (maio de 2026)."
							},
							"response": []
						},
						{
							"name": "UC9 - Listar Meus Pedidos Entregues",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/pedidos/entregues/meus?inicio=2026-05-01T00:00:00&fim=2026-05-31T23:59:59",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"pedidos",
										"entregues",
										"meus"
									],
									"query": [
										{
											"key": "inicio",
											"value": "2026-05-01T00:00:00"
										},
										{
											"key": "fim",
											"value": "2026-05-31T23:59:59"
										}
									]
								},
								"description": "Retorna a listagem dos pedidos que pertencem estritamente ao cliente atualmente logado no cabeçalho Basic Auth (`authEmail`) e que foram concluídos/entregues no período definido."
							},
							"response": []
						}
					]
